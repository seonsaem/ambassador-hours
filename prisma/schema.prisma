generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String?
  role      String   @default("USER")
  status    String   @default("INVITED")
  createdAt DateTime @default(now())
  requests  ActivityRequest[] @relation("UserRequests")
  createdRequests ActivityRequest[] @relation("CreatedRequests")
  files     FileStore[]
  notices   Notice[]  @relation("AuthoredNotices")
  pushSubscriptions PushSubscription[]
}

model ActivityCategory {
  id            Int      @id @default(autoincrement())
  categoryName  String
  activityType  String
  assignedHours Float
  isActive      Boolean  @default(true)
  department    String?
  requests      ActivityRequest[]
  maxHours      Float?
}

model ActivityRequest {
  id              Int      @id @default(autoincrement())
  userId          Int
  categoryId      Int
  activityType    String
  appliedHours    Float
  description     String
  evidenceFileUrl String?
  status          String   @default("PENDING")
  rejectedReason  String?
  bulkLabel       String?
  createdAt       DateTime @default(now())
  activityDate    DateTime @default(now())
  user            User     @relation("UserRequests", fields: [userId], references: [id])
  category        ActivityCategory @relation(fields: [categoryId], references: [id])
  createdById     Int?
  createdBy       User?    @relation("CreatedRequests", fields: [createdById], references: [id])
}

model Notice {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  isPinned  Boolean  @default(false)
  authorId  Int
  author    User     @relation("AuthoredNotices", fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FileStore {
  id           String   @id @default(uuid())
  filename     String
  mimeType     String
  data         String   // Base64 encoded string
  uploadedById Int?     // Nullable for backward compatibility
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  userId    Int
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
